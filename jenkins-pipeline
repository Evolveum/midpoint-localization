podTemplate(
        activeDeadlineSeconds: 600, // 10m limit is more than enough for localization
        idleMinutes: 1,
        // Secret volume with maven settings.xml for deploy, see also sim-link in "build" stage.
        volumes: [secretVolume(secretName: "jenkins-nexus",mountPath: "/root/jenkins-nexus")],
        workspaceVolume: dynamicPVC(requestsSize: "5Gi"),
        containers: [
                containerTemplate(name: 'jnlp',
                        image: 'jenkins/inbound-agent:4.13-2-alpine',
                        runAsUser: '0',
                        resourceRequestCpu: '1',
                        resourceLimitCpu: '1',
                        resourceRequestMemory: '1Gi',
                        resourceLimitMemory: '1Gi'),
                containerTemplate(name: 'maven',
                        image: params.BUILDER_IMAGE ?: 'maven:3.8.5-openjdk-17',
                        runAsUser: '0',
                        ttyEnabled: true,
                        command: 'cat',
                        resourceRequestCpu: '1',
                        resourceLimitCpu: '1',
                        resourceRequestMemory: '1Gi',
                        resourceLimitMemory: '1Gi'),
                containerTemplate(
                        name: 'tx',
                        image: 'transifex/txcli:latest',
                        command: 'cat',
                        ttyEnabled: true,
                        resourceRequestCpu: '200m',
                        resourceRequestMemory: '256Mi'
                ),
        ]
) {
    node(POD_LABEL) {
        stage("checkout") {
            git branch: params.BRANCH ?: 'master',
                    url: 'https://github.com/Evolveum/midpoint-localization.git'
            echo "git checkout done..."
        }
        stage("transifex") {
            container('tx') {
                withCredentials([
                        string(credentialsId: 'transifex-token', variable: 'TX_TOKEN'),
                        string(credentialsId: 'github-token', variable: 'GIT_TOKEN')]) {
                    sh """#!/bin/bash -ex
                        tx --version
                        
                        # create ~/.transifexrc using the token, then pull all files and overwrite local
                        tx login --token "$TX_TOKEN"
                        tx pull -fa
                        
                        rm localization/Midpoint_en.properties
                        mv localization/Midpoint_en_US.properties localization/Midpoint_en.properties
                        rm localization/schema_en.properties
                        mv localization/schema_en_US.properties localization/schema_en.properties
                        
                        # Remove all untracked files/dirs brought by tx
                        git clean -fd
            
                        # Stage any changes to tracked files
                        git add -A
                        
                        # If there are staged changes, commit and push
                        if ! git diff --staged --quiet; then
                            git config user.email "ci@jenkins"
                            git config user.name "jenkins-ci"
                            git commit -m "Automatic sync from Transifex, thanks to all Transifex contributors"
                            
                            # Avoid leaking token in logs
                            set +x
                            git remote set-url origin https://$GIT_TOKEN@github.com/Evolveum/midpoint-localization.git
                            git push origin ${params.BRANCH ?: 'master'}
                            set -x
                        else
                            echo "No tracked changes to commit."
                        fi
                    """
                }
            }
        }
        stage("build") {
            container('maven') {
                sh """#!/bin/bash -ex
                    # .m2 is mutable and short-term, we just sym-link the settings.xml there.
                    mkdir -p /root/.m2
                    ln -s ../jenkins-nexus/settings.xml /root/.m2/settings.xml

                    if [ '${params.VERBOSE}' = '1' ]
                    then
                        env | sort
                        mvn --version
                        df -h
                    fi

                    mvn -B -ntp -DskipTests clean deploy

                    if [ '${params.VERBOSE}' = '1' ]
                    then
                        df -h
                    fi
                """
            }
        }
    }
}
